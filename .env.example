# ─── Back4App / Parse Configuration ───────────────────────────────────────
# Get these from https://dashboard.back4app.com → Your App → Security & Keys

NEXT_PUBLIC_BACK4APP_APP_ID=your_app_id_here
NEXT_PUBLIC_BACK4APP_JS_KEY=your_javascript_key_here
NEXT_PUBLIC_BACK4APP_SERVER_URL=https://parseapi.back4app.com
NEXT_PUBLIC_BACK4APP_LIVE_QUERY_URL=wss://your-app-name.b4a.io

# ─── App Config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=AMT
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
